% ======================================================================
% List of support import options
% ======================================================================
%
% sameness provides a numbered evaluation‑step chart environment with
% automatic left rule and font configuration.
%
% -------------------------------------------------------------------
% Package options    (all with /sameness prefix; pass as key=value)
% -------------------------------------------------------------------
%
% unicodesup     = true | false   (default false)
%   Use Unicode superscript digits (⁰¹²…) instead of \textsuperscript.
%
% stepskip       = <glue>         (default 1ex plus 0.5ex)
%   Vertical space between steps.
%
% numbergap      = <dimen>        (default 0.75em)
%   Horizontal space between the left rule and the step number.
%
% rulethickness  = <dimen>        (default 0.75pt)
%   Thickness of the continuous left vertical rule.
%
% rulesep        = <dimen>        (default 0.5em)
%   Horizontal gap between left rule and text body.
%
% indentstep     = <dimen>        (default 1em)
%   Amount added/removed by \indentmore and \indentless.
%
% exprfont              = <family>  (shortcut)
% exprfont/family       = <family>
% exprfont/size         = <command> (default \normalsize)
% exprfont/shape        = <command> (default \upshape)
% exprfontcmd           = <command name without \>  (default empty)
%   Font settings for expression text.
%   family: system font name or "enc:family".
%
% commentfont           = <family>  (shortcut)
% commentfont/family    = <family>
% commentfont/size      = <command> (default \footnotesize)
% commentfont/shape     = <command> (default \itshape)
% commentfontcmd        = <command name without \>  (default empty)
%   Font settings for comment text (inside \comment{...}).
